{%- assign has_variants = false -%}
{% for product in section.settings['popular-products-list'] %}
  {% unless product.has_only_default_variant %}
    {% assign has_variants = true %}
  {% endunless %}
{% endfor %}

{% if has_variants %}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{% endif %}

{{ 'component-row-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'component-row-slider.js' | asset_url }}" defer="defer"></script>

<div class="page-width">
  <div id="{{ section.id }}" class="popular-products h-[60vh] md:h-[40vh]">
    <div class="popular-products__heading h-[10%] flex flex-row justify-between items-center md:mb-5 mb-8">
      <div class="heading__title text-gray-900 font-semibold text-[28px]">
        {{ section.settings['popular-products__title'] }}
      </div>
      <div class="heading__link font-medium text-[14px] text-gray-800">
        <a href="{{ section.settings.popular-products__url }}">View all ></a>
      </div>
    </div>
    <row-slider-component
      class="popular-products__slider h-[90%] !pb-[50px] md:!pb-[20px] md:!px-[20px]"
      style="--row-slider-slides-desktop: {{ section.settings.products-per-slide-desktop }}; --row-slider-slides-mobile: 1; --row-slider-gap: 24px;"
      data-loop="true"
    >
      <button type="button" class="row-slider__prev" aria-label="{{ 'general.slider.previous_slide' | t }}">
        <span class="icon svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <button type="button" class="row-slider__next" aria-label="{{ 'general.slider.next_slide' | t }}">
        <span class="icon svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <div class="row-slider__viewport h-full">
        <div class="popular-products__container row-slider__track h-full">
          {% for product in section.settings['popular-products-list'] limit: 8 %}
            {% render 'custom-product-card',
                    card_product: product,
                    show_secondary_image: true,
                    lazy_load: true,
                    show_add_to_cart: true,
                    show_variant_picker: true
                  %}
          {% endfor %}
        </div>
      </div>
    </row-slider-component>
  </div>
</div>
<style>
  .popular-products {
    margin: 56px 0;
  }
  .popular-products__container .swatch {
    width: 16px;
  }
</style>
{% schema %}
{
  "name": "Popular Products",
  "class": "popular-products",
  "settings": [
    {
      "type": "header",
      "content": "Popular Products Settings",
      "info": "Setting for popular products section"
    },
    {
      "type": "text",
      "id": "popular-products__title",
      "label": "Title",
      "default": "Popular products"
    },
    {
      "type": "url",
      "id": "popular-products__url",
      "label": "View all link to"
    },
    {
      "type": "product_list",
      "id": "popular-products-list",
      "label": "Select your products",
      "limit": 16
    },
    {
      "type": "range",
      "id": "products-per-slide-desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Products per slide (desktop)",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Popular Product"
    }
  ]
}
{% endschema %}
