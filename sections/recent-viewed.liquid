{{ 'component-row-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'component-row-slider.js' | asset_url }}" defer="defer"></script>

<div class="page-width">
  <div id="{{ section.id }}" class="recent-viewed">
    <div class="recent-viewed__heading flex flex-row justify-between items-center md:mb-5 mb-8">
      <div class="heading__title text-gray-900 font-semibold text-[28px]">
        {{ section.settings['recent-viewed__title'] }}
      </div>
    </div>
    <row-slider-component
      class="recent-viewed__slider h-[400px] md:h-[300px] !p-[6px] md:!p-[24px] md:pb-20 pb-40!"
      style="--row-slider-slides-desktop: {{ section.settings.products-per-slide-desktop }}; --row-slider-slides-mobile: {{ section.settings.products-per-slide-mobile }}; --row-slider-gap: 24px;"
      data-loop="true"
    >
      <button type="button" class="row-slider__prev" aria-label="{{ 'general.slider.previous_slide' | t }}">
        <span class="icon svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <button type="button" class="row-slider__next" aria-label="{{ 'general.slider.next_slide' | t }}">
        <span class="icon svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <div class="row-slider__viewport h-full">
        <div class="recent-viewed__container row-slider__track h-full"></div>
      </div>
    </row-slider-component>
  </div>
</div>
{%- comment -%}
  The row-slider-component is initialized exactly once, from inside the
  fetch().then() below, after the product cards have been injected into
  .recent-viewed__container. This is deliberate: initializing it earlier,
  while the container is still empty, previously caused a double-init bug
  with Swiper (see .docs/BE.md). RowSliderComponent's connectedCallback
  already no-ops on an empty container, so the async .refresh() call here
  is the only place setup() ever runs for this instance.
{%- endcomment -%}
<style>
  .recent-viewed {
    margin: 56px 0;
  }

  .recent-viewed__container .swatch {
    width: 16px;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', async function () {
    if (window.Shopify && window.Shopify.designMode) {
      // In theme editor - skip or show placeholder
      const container = document.querySelector('.recent-viewed__container');
      container.innerHTML = '<p class="p-4">Recently viewed products are not available in theme editor preview.</p>';
      return;
    }
    const container = document.querySelector('.recent-viewed__container');
    const sliderEl = document.querySelector('.recent-viewed__slider');
    let viewed = JSON.parse(localStorage.getItem('viewed_products') || '[]');

    viewed = viewed.slice(1, 9);
    if (viewed.length === 0) {
      container.innerHTML = '<p class="p-4">No recently viewed products.</p>';
      return;
    }

    function fetchProductHTML(card_product) {
      const cacheKey = `rv:${card_product}`;
      const cached = sessionStorage.getItem(cacheKey);
      if (cached !== null) {
        return Promise.resolve(cached);
      }
      return fetch(`/products/${card_product}?sections=custom-product-card`)
        .then((response) => {
          if (!response.ok) {
            throw new Error(`Failed to load product: ${card_product}`);
          }
          return response.json();
        })
        .then((data) => {
          const htmlString = data['custom-product-card'] || '';
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = htmlString;

          const wrapper = tempDiv.querySelector('#shopify-section-custom-product-card');
          const inner = wrapper ? wrapper.innerHTML : htmlString;
          try {
            sessionStorage.setItem(cacheKey, inner);
          } catch (e) {
            /* storage full / unavailable — skip caching */
          }
          return inner;
        })
        .catch((error) => {
          console.error(error);
          return '';
        });
    }

    container.innerHTML = ''; // Clear container before appending

    Promise.all(viewed.map((handle) => fetchProductHTML(handle))).then((productsHTML) => {
      productsHTML.forEach((html) => {
        if (html) {
          container.insertAdjacentHTML('beforeend', html);
        }
      });
      if (sliderEl && typeof sliderEl.refresh === 'function') {
        sliderEl.refresh();
      }
      // Quick-add and wishlist clicks are handled by document-level delegation;
      // only repaint wishlist icon state for the freshly injected cards.
      if (window.paintWishlistIcons) window.paintWishlistIcons(container);
    });
  });
</script>
<script>
  (function () {
    var productHandle = '{{ product.handle }}';
    var viewed = JSON.parse(localStorage.getItem('viewed_products') || '[]');

    // Remove if already exists to avoid duplicates
    var index = viewed.indexOf(productHandle);
    if (index !== -1) viewed.splice(index, 1);

    // Add to front
    viewed.unshift(productHandle);

    // Keep only last 20 viewed products (optional)
    viewed = viewed.slice(0, 20);

    localStorage.setItem('viewed_products', JSON.stringify(viewed));
  })();
</script>
{% schema %}
{
  "name": "Recent Viewed",
  "class": "recent-viewed",
  "settings": [
    {
      "type": "text",
      "id": "recent-viewed__title",
      "label": "Title",
      "default": "Recent Viewed"
    },
    {
      "type": "range",
      "id": "products-per-slide-desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Products per slide (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "products-per-slide-mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Products per slide (mobile)",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Recent Viewed Products"
    }
  ]
}
{% endschema %}
