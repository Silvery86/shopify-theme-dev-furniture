<div id="emailPopupForm" class="hidden">
  {% form 'customer', id: 'email-subscribe-form', class: 'email-popup-form w-full' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="flex w-full flex-col gap-4 sm:flex-row sm:items-stretch">
      <input
        type="email"
        name="contact[email]"
        placeholder="Enter your email address"
        required
        autocomplete="email"
        class="w-full flex-1 rounded-full border border-gray-300 bg-white px-6 py-3.5 text-[16px] text-gray-900 placeholder:text-gray-500 transition-colors duration-300 focus:border-gray-600 focus:outline-none sm:rounded-l-full sm:rounded-r-none"
      >
      <button
        type="submit"
        class="group inline-flex w-full shrink-0 items-center justify-center gap-2 rounded-2xl bg-gray-800 px-8 py-3.5 text-[16px] font-medium text-gray-100 transition-all duration-300 hover:border hover:border-gray-900 hover:bg-gray-100 hover:text-gray-900 active:scale-[0.98] sm:w-auto sm:rounded-l-none sm:rounded-r-full"
      >
        <span>Subscribe</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </button>
    </div>
    <p class="mt-4 text-center text-[12px] text-gray-400">No spam, unsubscribe anytime.</p>
  {% endform %}
</div>

<div id="emailPopup"></div>
<script src="{{ 'vite-email-popup.js' | asset_url }}" defer></script>
